a-row=\"1\" data-col=\"1\">b_Intercept</td>\n                  <td data-row=\"1\" data-col=\"2\">0.05</td>\n                </tr>\n                <tr>\n                  <td data-row=\"2\" data-col=\"1\"></td>\n                  <td data-row=\"2\" data-col=\"2\">[-0.15, 0.25]</td>\n                </tr>\n                <tr>\n                  <td data-row=\"3\" data-col=\"1\">b_t</td>\n                  <td data-row=\"3\" data-col=\"2\">0.00</td>\n                </tr>\n                <tr>\n                  <td data-row=\"4\" data-col=\"1\"></td>\n                  <td data-row=\"4\" data-col=\"2\">[-0.00, 0.00]</td>\n                </tr>\n                <tr>\n                  <td data-row=\"5\" data-col=\"1\">b_lag1</td>\n                  <td data-row=\"5\" data-col=\"2\">0.97</td>\n                </tr>\n                <tr>\n                  <td data-row=\"6\" data-col=\"1\"></td>\n                  <td data-row=\"6\" data-col=\"2\">[0.95, 1.00]</td>\n                </tr>\n                <tr>\n                  <td data-row=\"7\" data-col=\"1\">sigma</td>\n                  <td data-row=\"7\" data-col=\"2\">0.38</td>\n                </tr>\n                <tr>\n                  <td data-row=\"8\" data-col=\"1\"></td>\n                  <td data-row=\"8\" data-col=\"2\">[0.35, 0.41]</td>\n                </tr>\n                <tr>\n                  <td data-row=\"9\" data-col=\"1\">Num.Obs.</td>\n                  <td data-row=\"9\" data-col=\"2\">347</td>\n                </tr>\n                <tr>\n                  <td data-row=\"10\" data-col=\"1\">R2</td>\n                  <td data-row=\"10\" data-col=\"2\">0.944</td>\n                </tr>\n                <tr>\n                  <td data-row=\"11\" data-col=\"1\">R2 Adj.</td>\n                  <td data-row=\"11\" data-col=\"2\">0.943</td>\n                </tr>\n                <tr>\n                  <td data-row=\"12\" data-col=\"1\">ELPD</td>\n                  <td data-row=\"12\" data-